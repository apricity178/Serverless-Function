{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "city-data.js", "use": "@vercel/static" },
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "api/weather.js", "use": "@vercel/node" },
    { "src": "api/cron.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/proxy", "dest": "/api/proxy.js" },
    { "src": "/api/weather", "dest": "/api/weather.js" },
    { "src": "/api/cron", "dest": "/api/cron.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "0 8 * * *" },
    { "path": "/api/cron", "schedule": "23 11 * * *" }
  ]
}
